# Get your free key at https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
# Used as a last-resort fallback when all other scraping strategies fail for a company
RAPIDAPI_KEY=your_rapidapi_key_here

# Telegram notifications — get these by messaging @BotFather on Telegram:
#   1. /newbot → gives you the BOT_TOKEN
#   2. Start a chat with your bot, then visit:
#      https://api.telegram.org/bot<BOT_TOKEN>/getUpdates
#      to find your CHAT_ID (look for "id" inside "chat")
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here